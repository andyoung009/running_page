{
  "name": "yihong.run",
  "description": "Yi hong - running page",
  "version": "2.0.0",
  "author": "Yi Hong <zouzou0208@gmail.com>",
  "dependencies": {
    "@mapbox/polyline": "^1.2.1",
    "gcoord": "^0.3.2",
    "html2canvas": "^1.4.1",
    "mapbox-gl": "^3.23.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-map-gl": "^8.1.1",
    "recharts": "^2.15.2"
  },
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "data:clean": "rm -f run_page/data.db {GPX,TCX,FIT}_OUT/* activities/* src/static/activities.json",
    "data:download:garmin": "python3 run_page/garmin_sync.py",
    "data:analysis": "python3 run_page/gen_svg.py --from-db --type github --output assets/github.svg",
    "build": "tsc -b && vite build",
    "develop": "vite dev",
    "dev": "vite dev",
    "preview": "vite preview",
    "serve": "vite serve",
    "lint": "eslint src --ext .ts,.tsx --fix",
    "check": "prettier --check \"src/main.tsx\" \"src/**/*.{css,module.css,json,ts,tsx}\" \"*.{yaml,json,ts}\"",
    "format": "prettier --write \"src/main.tsx\" \"src/**/*.{css,module.css,json,ts,tsx}\" \"*.{yaml,json,ts}\"",
    "ci": "pnpm run format && pnpm run lint && pnpm run build"
  },
  "engineStrict": true,
  "browserslist": "defaults, not ie 11",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yihong0618/running_page"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.32.0",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@tailwindcss/vite": "^4.1.11",
    "@types/mapbox__polyline": "^1.0.5",
    "@types/node": "^24.2.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^16.3.0",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.13",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.5.3",
    "vite": "^7.1.2"
  },
  "pnpm": {
    "overrides": {
      "@types/node": "^24.2.1"
    }
  }
}
